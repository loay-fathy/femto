# Copy to .env.local and fill in. .env.local is gitignored.
# The contact + newsletter forms POST to /api/contact and /api/newsletter,
# which use Resend (https://resend.com) for email delivery and list storage.

# Resend API key — https://resend.com/api-keys
RESEND_API_KEY=

# Resend Audience ID that newsletter sign-ups are added to.
# Create one at https://resend.com/audiences and paste its ID here.
RESEND_AUDIENCE_ID=

# Sender identity for contact-form emails. The domain MUST be verified in Resend
# (https://resend.com/domains). Before verifying a domain you can test with
# "Femto Isotope <onboarding@resend.dev>".
CONTACT_FROM_EMAIL="Femto Isotope <noreply@femtoisotope.com>"

# Where contact-form enquiries are delivered. Defaults to CONTACT.email in
# lib/data.ts (info@femtoisotope.com) if unset.
CONTACT_INBOX_EMAIL=info@femtoisotope.com
